<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Jon's Essay Helper</title>
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Configure Tailwind Dark Mode -->
    <script>
        tailwind.config = { darkMode: 'class', }
    </script>

    <!-- React & ReactDOM -->
    <script crossorigin src="https://unpkg.com/react@18/umd/react.development.js"></script>
    <script crossorigin src="https://unpkg.com/react-dom@18/umd/react-dom.development.js"></script>
    
    <!-- Babel for JSX -->
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>

    <style>
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; background-color: #f3f4f6; transition: background-color 0.3s ease; }
        html.dark body { background-color: #111827; }
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #f1f1f1; }
        html.dark ::-webkit-scrollbar-track { background: #1f2937; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }
        html.dark ::-webkit-scrollbar-thumb { background: #4b5563; }
        ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
        html.dark ::-webkit-scrollbar-thumb:hover { background: #6b7280; }
        .phrase-btn:active { transform: scale(0.98); }
        .zoom-container { transform-origin: top left; transition: transform 0.2s ease; }
    </style>
</head>
<body>
    <div id="root"></div>

    <script type="text/babel">
        const { useState, useEffect, useRef } = React;

        function useLocalStorage(key, initialValue) {
            const [storedValue, setStoredValue] = useState(() => {
                try {
                    const item = window.localStorage.getItem(key);
                    return item ? JSON.parse(item) : initialValue;
                } catch (error) {
                    console.error("Error reading localStorage", error);
                    return initialValue;
                }
            });

            const setValue = (value) => {
                try {
                    const valueToStore = value instanceof Function ? value(storedValue) : value;
                    setStoredValue(valueToStore);
                    window.localStorage.setItem(key, JSON.stringify(valueToStore));
                } catch (error) {
                    console.error("Error setting localStorage", error);
                }
            };
            return [storedValue, setValue];
        }

        const countWords = (str) => {
            if (!str) return 0;
            return str.trim().split(/\s+/).filter(word => word.length > 0).length;
        };

        const calculateDaysLeft = (dueDate) => {
            if (!dueDate) return null;
            const due = new Date(dueDate);
            const today = new Date();
            const diffTime = due - today;
            return Math.ceil(diffTime / (1000 * 60 * 60 * 24));
        };

        const PROCESS_WORDS = [
            { word: "Analyse", def: "Discuss in detail - resolve into component parts, identify separate factors." },
            { word: "Appraise", def: "Evaluate, find the value of... consider positive/negative points." },
            { word: "Argue", def: "Make a case for or against - points must be supported with evidence." },
            { word: "Assess", def: "Give careful consideration to factors, identify most important. Estimate worth." },
            { word: "Compare", def: "Look for similarities and differences. Reach conclusion to relative merits." },
            { word: "Contrast", def: "Set items/opinions in opposition to sharply illustrate differences." },
            { word: "Criticise", def: "Make a judgment backed up with argument and evidence." },
            { word: "Evaluate", def: "Assess and give your judgment, support with references." },
            { word: "Justify", def: "Give reasons or evidence to support your opinion or view." }
        ];

        const PHRASEBANK = [
            { category: "Alternatives for 'However' (Counter Points)", phrases: ["Nevertheless, ", "Conversely, ", "On the contrary, ", "In contrast, ", "Alternatively, "] },
            { category: "Alternatives for 'This shows'", phrases: ["This demonstrates...", "This indicates...", "This implies...", "This suggests...", "This reveals...", "This highlights..."] },
            { category: "Strength of Evidence", phrases: ["The existing evidence for X is strong.", "There is limited evidence to suggest that...", "The evidence presented clearly indicates...", "Mounting evidence suggests..."] },
            { category: "Adding / Emphasising", phrases: ["Furthermore, ", "Moreover, ", "In addition to this, ", "Equally important is..."] },
            { category: "Concluding / Causal", phrases: ["Thus, ", "Therefore, ", "Consequently, ", "As a result, ", "In summary, "] }
        ];

        const SOURCE_TYPES = ["Peer-Reviewed Journal", "Academic Textbook", "Lecture/Reading List", "Reputable Website", "Other/Unverified"];

        const createNewEssay = () => ({
            id: Date.now().toString(),
            title: "New Essay Draft",
            dueDate: "",
            isCompleted: false,
            setup: { question: "", processWord: "", thesis: "", theory: "", targetWordCount: "1500" },
            brainstorm: { 
                pros: [{ id: Date.now(), signpost: "", point: "", evidence: "", evidence2: "", explain: "", link: "" }], 
                cons: [{ id: Date.now() + 1, signpost: "", point: "", evidence: "", evidence2: "", explain: "", critique: "", explainCritique: "", link: "", miniConclusion: "" }] 
            },
            sources: {
                introStat: "", introDef1: "", introDef2: "",
                bodySources: [{ id: 1, point: "", source: "", fullRef: "", type: "Peer-Reviewed Journal" }],
                bibliography: "" 
            },
            intro: { statOpening: "", background: "", defineWords: "", thesis: "", structure: "" },
            bodyParas: [
                { id: 1, type: "PRO", signpost: "", source: "", source2: "", explain: "", critical: "", explainCritique: "", caseStudy: "", link: "", evaluation: "" }
            ],
            conclusion: { summarise: "", evaluate: "", limitations: "", future: "" }
        });

        // --- Custom Component: Auto-Expanding Textarea ---
        const AutoExpandTextarea = ({ value, onChange, placeholder, expand, className }) => {
            const textareaRef = useRef(null);

            useEffect(() => {
                if (textareaRef.current) {
                    if (expand) {
                        textareaRef.current.style.height = 'auto';
                        textareaRef.current.style.height = textareaRef.current.scrollHeight + 'px';
                        textareaRef.current.style.overflow = 'hidden';
                    } else {
                        textareaRef.current.style.height = '42px'; // roughly one line height
                        textareaRef.current.style.overflow = 'auto';
                    }
                }
            }, [value, expand]);

            return (
                <textarea
                    ref={textareaRef}
                    value={value}
                    onChange={(e) => onChange(e.target.value)}
                    placeholder={placeholder}
                    className={`w-full p-2 text-sm rounded outline-none focus:ring-1 resize-none ${className}`}
                    rows={1}
                />
            );
        };

        function App() {
            const [essays, setEssays] = useLocalStorage("essay_architect_projects", []);
            const [activeEssayId, setActiveEssayId] = useState(null);
            const [notification, setNotification] = useState("");
            const [isDarkMode, setIsDarkMode] = useLocalStorage("essay_architect_darkmode", false);

            useEffect(() => {
                if (isDarkMode) document.documentElement.classList.add('dark');
                else document.documentElement.classList.remove('dark');
            }, [isDarkMode]);

            useEffect(() => {
                const today = new Date();
                let changed = false;
                const cleanedEssays = essays.filter(essay => {
                    if (essay.isCompleted && essay.dueDate) {
                        const due = new Date(essay.dueDate);
                        const diffDays = Math.ceil((today - due) / (1000 * 60 * 60 * 24));
                        if (diffDays > 30) {
                            changed = true;
                            return false; 
                        }
                    }
                    return true;
                });
                if (changed) setEssays(cleanedEssays);
            }, []);

            const activeEssay = essays.find(e => e.id === activeEssayId);

            const showNotification = (msg) => {
                setNotification(msg);
                setTimeout(() => setNotification(""), 3000);
            };

            const handleCreateEssay = () => {
                const newEssay = createNewEssay();
                setEssays([...essays, newEssay]);
                setActiveEssayId(newEssay.id);
            };

            const handleDeleteEssay = (id) => {
                if (window.confirm("Delete this essay plan forever?")) {
                    setEssays(essays.filter(e => e.id !== id));
                    if (activeEssayId === id) setActiveEssayId(null);
                }
            };

            const updateActiveEssay = (updatedEssay) => setEssays(essays.map(e => e.id === updatedEssay.id ? updatedEssay : e));

            return (
                <div className="h-screen w-full flex flex-col overflow-hidden bg-gray-50 dark:bg-gray-900 text-gray-800 dark:text-gray-200 transition-colors duration-300">
                    <header className="bg-indigo-700 dark:bg-indigo-900 text-white p-4 shadow-md flex justify-between items-center z-20 shrink-0">
                        <div className="flex items-center gap-4">
                            <h1 className="text-2xl font-bold tracking-tight cursor-pointer" onClick={() => setActiveEssayId(null)}>
                                🏛️ Jon's Essay Helper
                            </h1>
                            {activeEssayId && (
                                <button onClick={() => setActiveEssayId(null)} className="text-indigo-200 hover:text-white text-sm bg-indigo-800 dark:bg-indigo-950 px-3 py-1 rounded">
                                    ← Back to Dashboard
                                </button>
                            )}
                        </div>
                        <div className="flex items-center gap-4">
                            <button onClick={() => setIsDarkMode(!isDarkMode)} className="text-lg p-2 rounded-full hover:bg-indigo-600 dark:hover:bg-indigo-800 transition shadow-sm bg-indigo-800 dark:bg-indigo-950" title="Toggle Dark Mode">
                                {isDarkMode ? "☀️" : "🌙"}
                            </button>
                            <div className="text-sm font-medium opacity-80 hidden sm:block">Local Autosave Active</div>
                        </div>
                    </header>

                    {notification && (
                        <div className="absolute top-16 right-4 bg-green-500 text-white px-4 py-2 rounded shadow-lg font-medium text-sm z-50 animate-bounce">
                            {notification}
                        </div>
                    )}

                    <main className="flex-1 overflow-hidden flex">
                        {!activeEssayId ? (
                            <Dashboard essays={essays} onCreate={handleCreateEssay} onOpen={setActiveEssayId} onDelete={handleDeleteEssay}
                                onToggleComplete={(id, status) => {
                                    const essay = essays.find(e => e.id === id);
                                    updateActiveEssay({ ...essay, isCompleted: status });
                                    showNotification(status ? "Essay marked as complete!" : "Essay reopened!");
                                }} 
                            />
                        ) : (
                            <Workspace essay={activeEssay} updateEssay={updateActiveEssay} notify={showNotification} />
                        )}
                    </main>
                </div>
            );
        }

        function Dashboard({ essays, onCreate, onOpen, onDelete, onToggleComplete }) {
            const sortedEssays = [...essays].sort((a, b) => {
                if (a.isCompleted && !b.isCompleted) return 1;
                if (!a.isCompleted && b.isCompleted) return -1;
                if (a.dueDate && b.dueDate) return new Date(a.dueDate) - new Date(b.dueDate);
                if (a.dueDate) return -1;
                if (b.dueDate) return 1;
                return b.id - a.id;
            });

            return (
                <div className="flex-1 overflow-y-auto p-8">
                    <div className="max-w-6xl mx-auto">
                        <div className="flex justify-between items-end mb-8 border-b border-gray-200 dark:border-gray-700 pb-4">
                            <div>
                                <h2 className="text-3xl font-bold text-gray-800 dark:text-white">Your Essay Plans</h2>
                                <p className="text-gray-600 dark:text-gray-400 mt-1">Manage, plan, and write multiple essays directly in your browser.</p>
                            </div>
                            <button onClick={onCreate} className="bg-indigo-600 dark:bg-indigo-500 text-white px-6 py-3 rounded-lg font-bold shadow hover:bg-indigo-700 dark:hover:bg-indigo-600 transition">
                                + Create New Essay Plan
                            </button>
                        </div>

                        {essays.length === 0 ? (
                            <div className="text-center p-12 bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700">
                                <p className="text-gray-500 dark:text-gray-400 mb-4">You don't have any essay plans yet.</p>
                                <button onClick={onCreate} className="text-indigo-600 dark:text-indigo-400 font-bold hover:underline">Start your first plan</button>
                            </div>
                        ) : (
                            <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                                {sortedEssays.map(essay => {
                                    const daysLeft = calculateDaysLeft(essay.dueDate);
                                    let badgeColor = "bg-gray-100 dark:bg-gray-700 text-gray-800 dark:text-gray-200";
                                    let urgencyText = "No Due Date";
                                    
                                    if (daysLeft !== null) {
                                        if (daysLeft < 0) { badgeColor = "bg-red-100 dark:bg-red-900/50 text-red-800 dark:text-red-200"; urgencyText = "Overdue"; }
                                        else if (daysLeft <= 3) { badgeColor = "bg-red-100 dark:bg-red-900/50 text-red-800 dark:text-red-200"; urgencyText = `${daysLeft} days left!`; }
                                        else if (daysLeft <= 7) { badgeColor = "bg-yellow-100 dark:bg-yellow-900/50 text-yellow-800 dark:text-yellow-200"; urgencyText = `${daysLeft} days left`; }
                                        else { badgeColor = "bg-green-100 dark:bg-green-900/50 text-green-800 dark:text-green-200"; urgencyText = `${daysLeft} days left`; }
                                    }

                                    const totalWords = countWords(JSON.stringify(essay.intro) + JSON.stringify(essay.bodyParas) + JSON.stringify(essay.conclusion));
                                    const targetCount = parseInt(essay.setup.targetWordCount) || 1500;
                                    const minWords = Math.floor(targetCount * 0.9);
                                    const maxWords = Math.ceil(targetCount * 1.1);
                                    const inRange = totalWords >= minWords && totalWords <= maxWords;

                                    return (
                                        <div key={essay.id} className={`bg-white dark:bg-gray-800 p-6 rounded-xl shadow-sm border hover:shadow-md transition flex flex-col relative ${essay.isCompleted ? 'border-green-300 dark:border-green-700 opacity-80' : 'border-gray-200 dark:border-gray-700'}`}>
                                            {essay.isCompleted && (
                                                <div className="absolute top-0 right-0 bg-green-500 dark:bg-green-600 text-white text-xs font-bold px-3 py-1 rounded-bl-lg rounded-tr-xl shadow-sm">
                                                    COMPLETED
                                                </div>
                                            )}
                                            <div className="flex justify-between items-start mb-4">
                                                <h3 className={`font-bold text-xl line-clamp-2 pr-16 ${essay.isCompleted ? 'text-gray-500 dark:text-gray-400 line-through' : 'text-gray-800 dark:text-gray-100'}`}>
                                                    {essay.title || "Untitled Essay"}
                                                </h3>
                                            </div>
                                            <p className="text-sm text-gray-500 dark:text-gray-400 mb-4 line-clamp-2">{essay.setup.question || "No question defined yet."}</p>
                                            
                                            <div className="mt-auto pt-4 border-t border-gray-100 dark:border-gray-700 flex items-center justify-between">
                                                <span className={`text-xs font-bold px-2 py-1 rounded-full ${badgeColor}`}>
                                                    📅 {urgencyText}
                                                </span>
                                                <span className={`text-xs font-bold ${inRange ? 'text-green-600 dark:text-green-400' : 'text-gray-500 dark:text-gray-400'}`}>
                                                    {totalWords} / {targetCount} wds
                                                </span>
                                            </div>

                                            <div className="flex gap-2 mt-4 flex-wrap">
                                                <button onClick={() => onOpen(essay.id)} className="flex-1 bg-indigo-50 dark:bg-indigo-900/30 text-indigo-700 dark:text-indigo-300 py-2 rounded-lg text-sm font-bold hover:bg-indigo-100 dark:hover:bg-indigo-900/50 transition">
                                                    Open / Edit
                                                </button>
                                                <button onClick={() => onToggleComplete(essay.id, !essay.isCompleted)} className={`px-3 py-2 rounded-lg text-sm font-bold transition ${essay.isCompleted ? 'bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-600' : 'bg-green-50 dark:bg-green-900/30 text-green-600 dark:text-green-400 hover:bg-green-100 dark:hover:bg-green-900/50'}`}>
                                                    {essay.isCompleted ? 'Reopen' : 'Complete'}
                                                </button>
                                                <button onClick={() => onDelete(essay.id)} className="bg-red-50 dark:bg-red-900/30 text-red-600 dark:text-red-400 px-3 py-2 rounded-lg text-sm font-bold hover:bg-red-100 dark:hover:bg-red-900/50 transition">
                                                    Delete
                                                </button>
                                            </div>
                                        </div>
                                    );
                                })}
                            </div>
                        )}
                    </div>
                </div>
            );
        }

        const WordCountTextarea = ({ label, target, value, onChange, placeholder, helpText }) => {
            const count = countWords(value);
            const isOver = count > target + 10;
            const progress = Math.min((count / target) * 100, 100);

            return (
                <div className="mb-5">
                    <div className="flex justify-between items-end mb-1">
                        <label className="block text-sm font-bold text-gray-700 dark:text-gray-300">{label}</label>
                        <span className={`text-xs font-bold px-2 py-1 rounded ${isOver ? 'bg-red-100 text-red-700 dark:bg-red-900/50 dark:text-red-300' : 'bg-indigo-100 text-indigo-700 dark:bg-indigo-900/50 dark:text-indigo-300'}`}>
                            {count} / {target} wds
                        </span>
                    </div>
                    {helpText && <p className="text-xs text-gray-500 dark:text-gray-400 mb-2 italic">{helpText}</p>}
                    <textarea
                        className="w-full p-3 border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none resize-y min-h-[100px] text-gray-800 dark:text-gray-100 leading-relaxed"
                        value={value || ""}
                        onChange={(e) => onChange(e.target.value)}
                        placeholder={placeholder}
                    />
                    <div className="h-1 w-full bg-gray-200 dark:bg-gray-700 rounded-full mt-1 overflow-hidden">
                        <div className={`h-full ${isOver ? 'bg-red-500 dark:bg-red-400' : 'bg-indigo-500 dark:bg-indigo-400'}`} style={{ width: `${progress}%` }}></div>
                    </div>
                </div>
            );
        };

        function Workspace({ essay, updateEssay, notify }) {
            const [activeTab, setActiveTab] = useState("setup");
            const [showCheatSheet, setShowCheatSheet] = useState(true);
            const [expandCells, setExpandCells] = useLocalStorage("essay_expand_cells", true);

            const [isRefViewerOpen, setIsRefViewerOpen] = useState(false);
            const [referenceFiles, setReferenceFiles] = useState([]);
            const [activeRefId, setActiveRefId] = useState(null);
            const [docZoom, setDocZoom] = useState(1);

            const handleFileUpload = (e) => {
                const files = Array.from(e.target.files);
                if (files.length === 0) return;
                const newRefs = files.map(f => ({ id: Date.now().toString() + Math.random().toString(36).substr(2, 9), name: f.name, type: f.type, url: URL.createObjectURL(f) }));
                setReferenceFiles(prev => { const combined = [...prev, ...newRefs]; if (!activeRefId && combined.length > 0) setActiveRefId(combined[0].id); return combined; });
            };

            const removeReferenceFile = (idToRemove) => {
                const fileToRevoke = referenceFiles.find(f => f.id === idToRemove);
                if (fileToRevoke) URL.revokeObjectURL(fileToRevoke.url);
                const newRefs = referenceFiles.filter(f => f.id !== idToRemove);
                setReferenceFiles(newRefs);
                if (activeRefId === idToRemove) { setActiveRefId(newRefs.length > 0 ? newRefs[0].id : null); setDocZoom(1); }
            };

            useEffect(() => { setDocZoom(1); }, [activeRefId]);
            useEffect(() => { return () => referenceFiles.forEach(f => URL.revokeObjectURL(f.url)); }, []);

            const activeRefFile = referenceFiles.find(f => f.id === activeRefId);

            // Backward compatibility
            const currentBrainstorm = essay.brainstorm || { pros: [], cons: [] };
            const currentSources = essay.sources || { introStat: "", introDef1: "", introDef2: "", bodySources: [], bibliography: "" };
            const currentSetup = essay.setup || { question: "", processWord: "", thesis: "", theory: "", targetWordCount: "1500" };

            const updateRoot = (field, val) => updateEssay({ ...essay, [field]: val });
            const updateSetup = (field, val) => updateEssay({ ...essay, setup: { ...currentSetup, [field]: val } });
            const updateSources = (field, val) => updateEssay({ ...essay, sources: { ...currentSources, [field]: val } });
            const updateIntro = (field, val) => updateEssay({ ...essay, intro: { ...essay.intro, [field]: val } });
            const updateConclusion = (field, val) => updateEssay({ ...essay, conclusion: { ...essay.conclusion, [field]: val } });
            
            const addBrainstormPoint = (type) => {
                const newPoint = type === 'pros'
                    ? { id: Date.now(), signpost: "", point: "", evidence: "", evidence2: "", explain: "", link: "" }
                    : { id: Date.now(), signpost: "", point: "", evidence: "", evidence2: "", explain: "", critique: "", explainCritique: "", link: "", miniConclusion: "" };
                updateEssay({ ...essay, brainstorm: { ...currentBrainstorm, [type]: [...currentBrainstorm[type], newPoint] } });
            };
            const updateBrainstormField = (type, id, field, val) => {
                const newArr = currentBrainstorm[type].map(p => p.id === id ? { ...p, [field]: val } : p);
                updateEssay({ ...essay, brainstorm: { ...currentBrainstorm, [type]: newArr } });
            };
            const removeBrainstormPoint = (type, id) => {
                const newArr = currentBrainstorm[type].filter(p => p.id !== id);
                updateEssay({ ...essay, brainstorm: { ...currentBrainstorm, [type]: newArr } });
            };

            const updateBodySource = (id, field, val) => {
                const newSources = currentSources.bodySources.map(s => s.id === id ? { ...s, [field]: val } : s);
                updateSources("bodySources", newSources);
            };
            const addBodySource = () => {
                const newId = Date.now();
                updateSources("bodySources", [...(currentSources.bodySources || []), { id: newId, point: "", source: "", fullRef: "", type: "Peer-Reviewed Journal" }]);
            };
            const removeBodySource = (id) => updateSources("bodySources", currentSources.bodySources.filter(s => s.id !== id));

            const updateBodyPara = (id, field, val) => {
                const newParas = essay.bodyParas.map(p => p.id === id ? { ...p, [field]: val } : p);
                updateEssay({ ...essay, bodyParas: newParas });
            };
            const addParagraph = (type) => {
                const newId = Date.now();
                updateEssay({ ...essay, bodyParas: [...essay.bodyParas, { id: newId, type, signpost: "", source: "", source2: "", explain: "", critical: "", explainCritique: "", caseStudy: "", link: "", evaluation: "" }] });
            };
            const removeParagraph = (id) => updateEssay({ ...essay, bodyParas: essay.bodyParas.filter(p => p.id !== id) });

            const copyToClipboard = (text) => navigator.clipboard.writeText(text).then(() => notify("Copied to clipboard!"));

            // Interleaves Pro 1, Counter 1, Pro 2, Counter 2...
            const getInterleavedBrainstorm = () => {
                const interleaved = [];
                const max = Math.max(currentBrainstorm.pros.length, currentBrainstorm.cons.length);
                for (let i = 0; i < max; i++) {
                    if (currentBrainstorm.pros[i]) interleaved.push({ ...currentBrainstorm.pros[i], type: 'PRO', idx: i + 1 });
                    if (currentBrainstorm.cons[i]) interleaved.push({ ...currentBrainstorm.cons[i], type: 'COUNTER', idx: i + 1 });
                }
                return interleaved;
            };

            const copyBrainstormPlan = () => {
                let text = "ESSAY TEMPLATE / PARAGRAPH PLAN\n\n";
                text += `THESIS: ${currentSetup.thesis || 'Not yet defined'}\n`;
                text += `THEORY/FRAMEWORK: ${currentSetup.theory || 'Not yet defined'}\n\n`;
                text += "--- INTRODUCTION ---\n";
                text += `${essay.intro.statOpening || ''} ${essay.intro.background || ''} ${essay.intro.defineWords || ''} ${essay.intro.thesis || ''} ${essay.intro.structure || ''}\n\n`;
                
                text += "--- BODY PARAGRAPHS ---\n\n";
                const interleaved = getInterleavedBrainstorm();
                interleaved.forEach((p) => {
                    const label = p.type === 'PRO' ? `Pro Paragraph ${p.idx}` : `Counter Paragraph ${p.idx}`;
                    let para = "";
                    if (p.type === 'PRO') {
                        para = `${p.signpost || ''} ${p.point || ''} ${p.evidence || ''} ${p.evidence2 || ''} ${p.explain || ''} ${p.link || ''}`;
                    } else {
                        para = `${p.signpost || ''} ${p.point || ''} ${p.evidence || ''} ${p.evidence2 || ''} ${p.explain || ''} ${p.critique || ''} ${p.explainCritique || ''} ${p.link || ''} ${p.miniConclusion || ''}`;
                    }
                    text += `${label}:\n${para.replace(/\s+/g, ' ').trim()}\n\n`;
                });
                copyToClipboard(text);
            };

            const compileFullEssay = () => {
                const i = essay.intro;
                const introText = `${i.statOpening} ${i.background} ${i.defineWords} ${i.thesis} ${i.structure}`.trim();
                
                // Interleave actual Body Paragraphs (Pro 1, Con 1, Pro 2, Con 2)
                const pros = essay.bodyParas.filter(p => p.type === 'PRO');
                const cons = essay.bodyParas.filter(p => p.type === 'COUNTER');
                const interleavedBody = [];
                const maxLen = Math.max(pros.length, cons.length);
                for(let j=0; j<maxLen; j++) {
                    if (pros[j]) interleavedBody.push(pros[j]);
                    if (cons[j]) interleavedBody.push(cons[j]);
                }

                const bodyText = interleavedBody.map(p => {
                    return `${p.signpost} ${p.source} ${p.source2 || ''} ${p.explain} ${p.critical} ${p.explainCritique || ''} ${p.caseStudy} ${p.link} ${p.evaluation || ''}`.replace(/\s+/g, ' ').trim();
                }).join("\n\n");

                const c = essay.conclusion;
                const concText = `${c.summarise} ${c.evaluate} ${c.limitations} ${c.future}`.trim();

                const referencesText = currentSources.bibliography ? `\n\nReferences:\n${currentSources.bibliography}` : "";

                return `${introText}\n\n${bodyText}\n\n${concText}${referencesText}`;
            };

            const renderSetup = () => (
                <div className="space-y-6">
                    <div className="bg-white dark:bg-gray-800 p-6 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700">
                        <div>
                            <h2 className="text-2xl font-bold text-gray-800 dark:text-white">1. Setup & Intro Plan</h2>
                            <p className="text-gray-500 dark:text-gray-400 text-sm">Define your parameters, thesis, and sketch out the introduction.</p>
                        </div>
                        
                        <div className="grid grid-cols-1 md:grid-cols-3 gap-4 mt-6">
                            <div>
                                <label className="block text-sm font-bold text-gray-700 dark:text-gray-300 mb-1">Essay Title</label>
                                <input type="text" className="w-full p-3 bg-gray-50 dark:bg-gray-700 text-gray-800 dark:text-white border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none" 
                                    value={essay.title} onChange={e => updateRoot("title", e.target.value)} />
                            </div>
                            <div>
                                <label className="block text-sm font-bold text-gray-700 dark:text-gray-300 mb-1">Due Date</label>
                                <input type="date" className="w-full p-3 bg-gray-50 dark:bg-gray-700 text-gray-800 dark:text-white border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none [color-scheme:light] dark:[color-scheme:dark]" 
                                    value={essay.dueDate} onChange={e => updateRoot("dueDate", e.target.value)} />
                            </div>
                            <div>
                                <label className="block text-sm font-bold text-gray-700 dark:text-gray-300 mb-1">Target Word Count</label>
                                <div className="flex flex-col">
                                    <input type="number" className="w-full p-3 bg-gray-50 dark:bg-gray-700 text-gray-800 dark:text-white border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none" 
                                        value={currentSetup.targetWordCount || ""} onChange={e => updateSetup("targetWordCount", e.target.value)} placeholder="e.g. 1500" />
                                    {currentSetup.targetWordCount && (
                                        <span className="text-xs text-gray-500 dark:text-gray-400 font-medium mt-1">
                                            ±10%: {Math.floor(currentSetup.targetWordCount * 0.9)} to {Math.ceil(currentSetup.targetWordCount * 1.1)}
                                        </span>
                                    )}
                                </div>
                            </div>
                        </div>

                        <div className="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4">
                            <div>
                                <label className="block text-sm font-bold text-gray-700 dark:text-gray-300 mb-1">The Question</label>
                                <textarea className="w-full p-3 bg-gray-50 dark:bg-gray-700 text-gray-800 dark:text-white border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none" rows="2"
                                    value={currentSetup.question} onChange={e => updateSetup("question", e.target.value)} placeholder="What exactly are you answering?"></textarea>
                            </div>
                            <div>
                                <label className="block text-sm font-bold text-gray-700 dark:text-gray-300 mb-1">Process Word (From Step 1)</label>
                                <select className="w-full p-3 bg-gray-50 dark:bg-gray-700 text-gray-800 dark:text-white border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none"
                                    value={currentSetup.processWord} onChange={e => updateSetup("processWord", e.target.value)}>
                                    <option value="">Select process word...</option>
                                    {PROCESS_WORDS.map(pw => <option key={pw.word} value={pw.word}>{pw.word}</option>)}
                                </select>
                                {currentSetup.processWord && (
                                    <p className="text-sm mt-2 text-indigo-700 dark:text-indigo-300 bg-indigo-50 dark:bg-indigo-900/30 p-2 rounded-lg font-medium border border-indigo-100 dark:border-indigo-800">
                                        <strong>Meaning:</strong> {PROCESS_WORDS.find(p => p.word === currentSetup.processWord)?.def}
                                    </p>
                                )}
                            </div>
                        </div>

                        <div className="mt-6 border-t border-gray-200 dark:border-gray-700 pt-6">
                            <h3 className="text-lg font-bold text-indigo-800 dark:text-indigo-400 mb-4">Core Arguments & Framework</h3>
                            <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                                <div>
                                    <label className="block text-sm font-bold text-gray-700 dark:text-gray-300 mb-1">Working Thesis</label>
                                    <textarea className="w-full p-3 bg-white dark:bg-gray-700 text-gray-800 dark:text-white border border-indigo-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none font-medium resize-y" rows="3"
                                        value={currentSetup.thesis} onChange={e => { updateSetup("thesis", e.target.value); updateIntro("thesis", e.target.value); }} placeholder="State your main argument clearly (Anchor to a child)..."></textarea>
                                </div>
                                <div>
                                    <label className="block text-sm font-bold text-gray-700 dark:text-gray-300 mb-1">Theory / Theoretical Framework</label>
                                    <textarea className="w-full p-3 bg-white dark:bg-gray-700 text-gray-800 dark:text-white border border-indigo-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none resize-y" rows="3"
                                        value={currentSetup.theory || ""} onChange={e => updateSetup("theory", e.target.value)} placeholder="What academic theory or framework are you using to analyze the question?"></textarea>
                                </div>
                            </div>
                        </div>

                        <div className="mt-6 border-t border-gray-200 dark:border-gray-700 pt-6">
                            <h3 className="text-lg font-bold text-indigo-800 dark:text-indigo-400 mb-2">Introduction Planning</h3>
                            <p className="text-sm text-gray-500 dark:text-gray-400 mb-4">Sketch out the intro here. It automatically syncs with your writing tab.</p>
                            <div className="space-y-3 bg-gray-50 dark:bg-gray-900/50 p-4 rounded-lg border border-gray-200 dark:border-gray-700">
                                <AutoExpandTextarea expand={expandCells} value={essay.intro.statOpening} onChange={v => updateIntro("statOpening", v)} placeholder="Hook / Opening Stat (~50 words)..." className="bg-white dark:bg-gray-800 text-gray-800 dark:text-white border-gray-300 dark:border-gray-600" />
                                <AutoExpandTextarea expand={expandCells} value={essay.intro.background} onChange={v => updateIntro("background", v)} placeholder="Background / Value (~50 words)..." className="bg-white dark:bg-gray-800 text-gray-800 dark:text-white border-gray-300 dark:border-gray-600" />
                                <AutoExpandTextarea expand={expandCells} value={essay.intro.defineWords} onChange={v => updateIntro("defineWords", v)} placeholder="Define Process Words/Measures (~50 words)..." className="bg-white dark:bg-gray-800 text-gray-800 dark:text-white border-gray-300 dark:border-gray-600" />
                                <AutoExpandTextarea expand={expandCells} value={essay.intro.structure} onChange={v => updateIntro("structure", v)} placeholder="Structure / Map (~50 words: How will the essay flow?)..." className="bg-white dark:bg-gray-800 text-gray-800 dark:text-white border-gray-300 dark:border-gray-600" />
                            </div>
                        </div>
                    </div>

                    <div className="bg-white dark:bg-gray-800 p-6 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700">
                        <div className="flex flex-col md:flex-row justify-between items-start md:items-center mb-4 gap-4">
                            <div>
                                <h2 className="text-xl font-bold text-gray-800 dark:text-white mb-1">Brainstorming Board (Template Step 4)</h2>
                                <p className="text-gray-500 dark:text-gray-400 text-sm">Synthesize points. Ensure equal representation. Will export interleaved (Pro 1, Con 1...).</p>
                            </div>
                            <div className="flex items-center gap-3">
                                <label className="flex items-center gap-2 cursor-pointer text-sm font-bold text-gray-600 dark:text-gray-300">
                                    <input type="checkbox" checked={expandCells} onChange={e => setExpandCells(e.target.checked)} className="w-4 h-4 text-indigo-600 focus:ring-indigo-500" />
                                    Expand Cells
                                </label>
                                <button onClick={copyBrainstormPlan} className="bg-indigo-100 dark:bg-indigo-900/30 text-indigo-700 dark:text-indigo-300 px-4 py-2 rounded-lg text-sm font-bold hover:bg-indigo-200 dark:hover:bg-indigo-900/50 transition shadow-sm">
                                    📋 Export Plan
                                </button>
                            </div>
                        </div>
                        
                        <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div className="bg-green-50 dark:bg-green-900/20 p-4 rounded-lg border border-green-100 dark:border-green-800/50">
                                <div className="flex justify-between items-center mb-4">
                                    <h3 className="font-bold text-green-800 dark:text-green-400">Pro Points (For)</h3>
                                    <button onClick={() => addBrainstormPoint('pros')} className="text-xs bg-green-600 dark:bg-green-700 text-white px-3 py-1.5 rounded font-bold hover:bg-green-700 dark:hover:bg-green-600 shadow-sm">+ Add Paragraph</button>
                                </div>
                                <div className="space-y-4">
                                    {currentBrainstorm.pros.map((p, idx) => (
                                        <div key={p.id} className="bg-white dark:bg-gray-800 p-3 rounded-lg shadow-sm border border-green-200 dark:border-green-800/50 relative">
                                            <button onClick={() => removeBrainstormPoint('pros', p.id)} className="absolute top-2 right-2 text-gray-400 hover:text-red-500 font-bold px-2">✕</button>
                                            <span className="font-bold text-green-700 dark:text-green-500 text-xs mb-2 block uppercase tracking-wide">Pro Paragraph {idx + 1}</span>
                                            <div className="space-y-2">
                                                <AutoExpandTextarea expand={expandCells} className="bg-gray-50 dark:bg-gray-700 text-gray-800 dark:text-white border-gray-200 dark:border-gray-600 focus:ring-green-400"
                                                    placeholder="1a. Signpost (e.g. First, Furthermore)..." value={p.signpost || ''} onChange={e => updateBrainstormField('pros', p.id, 'signpost', e)} />
                                                <AutoExpandTextarea expand={expandCells} className="bg-gray-50 dark:bg-gray-700 text-gray-800 dark:text-white border-gray-200 dark:border-gray-600 focus:ring-green-400"
                                                    placeholder="1b. Point (~50w: Make a claim)..." value={p.point !== undefined ? p.point : (p.text || '')} onChange={e => updateBrainstormField('pros', p.id, 'point', e)} />
                                                <AutoExpandTextarea expand={expandCells} className="bg-gray-50 dark:bg-gray-700 text-gray-800 dark:text-white border-gray-200 dark:border-gray-600 focus:ring-green-400"
                                                    placeholder="2a. Evidence 1 (~50w: Jon, 2023 - did what?)..." value={p.evidence || ''} onChange={e => updateBrainstormField('pros', p.id, 'evidence', e)} />
                                                <AutoExpandTextarea expand={expandCells} className="bg-gray-50 dark:bg-gray-700 text-gray-800 dark:text-white border-gray-200 dark:border-gray-600 focus:ring-green-400"
                                                    placeholder="2b. Evidence 2 (Synthesize: Zubi, 2022 - agrees?)..." value={p.evidence2 || ''} onChange={e => updateBrainstormField('pros', p.id, 'evidence2', e)} />
                                                <AutoExpandTextarea expand={expandCells} className="bg-gray-50 dark:bg-gray-700 text-gray-800 dark:text-white border-gray-200 dark:border-gray-600 focus:ring-green-400"
                                                    placeholder="3. Explain (~75w+: 'This demonstrates...' / Relevance)..." value={p.explain || ''} onChange={e => updateBrainstormField('pros', p.id, 'explain', e)} />
                                                <AutoExpandTextarea expand={expandCells} className="bg-gray-50 dark:bg-gray-700 text-gray-800 dark:text-white border-gray-200 dark:border-gray-600 focus:ring-green-400"
                                                    placeholder="4. Link (~50w: Summarise -> Link thesis -> Hint next)..." value={p.link || ''} onChange={e => updateBrainstormField('pros', p.id, 'link', e)} />
                                            </div>
                                        </div>
                                    ))}
                                </div>
                            </div>

                            <div className="bg-red-50 dark:bg-red-900/20 p-4 rounded-lg border border-red-100 dark:border-red-800/50">
                                <div className="flex justify-between items-center mb-4">
                                    <h3 className="font-bold text-red-800 dark:text-red-400">Counter Points (Against)</h3>
                                    <button onClick={() => addBrainstormPoint('cons')} className="text-xs bg-red-600 dark:bg-red-700 text-white px-3 py-1.5 rounded font-bold hover:bg-red-700 dark:hover:bg-red-600 shadow-sm">+ Add Paragraph</button>
                                </div>
                                <div className="space-y-4">
                                    {currentBrainstorm.cons.map((c, idx) => (
                                        <div key={c.id} className="bg-white dark:bg-gray-800 p-3 rounded-lg shadow-sm border border-red-200 dark:border-red-800/50 relative">
                                            <button onClick={() => removeBrainstormPoint('cons', c.id)} className="absolute top-2 right-2 text-gray-400 hover:text-red-500 font-bold px-2">✕</button>
                                            <span className="font-bold text-red-700 dark:text-red-500 text-xs mb-2 block uppercase tracking-wide">Counter Paragraph {idx + 1}</span>
                                            <div className="space-y-2">
                                                <AutoExpandTextarea expand={expandCells} className="bg-gray-50 dark:bg-gray-700 text-gray-800 dark:text-white border-gray-200 dark:border-gray-600 focus:ring-red-400"
                                                    placeholder="1a. Signpost (Use alternative for However: Conversely, Nevertheless...)" value={c.signpost || ''} onChange={e => updateBrainstormField('cons', c.id, 'signpost', e)} />
                                                <AutoExpandTextarea expand={expandCells} className="bg-gray-50 dark:bg-gray-700 text-gray-800 dark:text-white border-gray-200 dark:border-gray-600 focus:ring-red-400"
                                                    placeholder="1b. Point (~50w: Counter claim)..." value={c.point !== undefined ? c.point : (c.text || '')} onChange={e => updateBrainstormField('cons', c.id, 'point', e)} />
                                                <AutoExpandTextarea expand={expandCells} className="bg-gray-50 dark:bg-gray-700 text-gray-800 dark:text-white border-gray-200 dark:border-gray-600 focus:ring-red-400"
                                                    placeholder="2a. Evidence 1 (~50w: Zubi, 2022 - found what?)..." value={c.evidence || ''} onChange={e => updateBrainstormField('cons', c.id, 'evidence', e)} />
                                                <AutoExpandTextarea expand={expandCells} className="bg-gray-50 dark:bg-gray-700 text-gray-800 dark:text-white border-gray-200 dark:border-gray-600 focus:ring-red-400"
                                                    placeholder="2b. Evidence 2 (Synthesize: Jon, 2023)..." value={c.evidence2 || ''} onChange={e => updateBrainstormField('cons', c.id, 'evidence2', e)} />
                                                <AutoExpandTextarea expand={expandCells} className="bg-gray-50 dark:bg-gray-700 text-gray-800 dark:text-white border-gray-200 dark:border-gray-600 focus:ring-red-400"
                                                    placeholder="3. Explain (~75w+: 'This implies...' / Relevance)..." value={c.explain || ''} onChange={e => updateBrainstormField('cons', c.id, 'explain', e)} />
                                                
                                                <div className="bg-red-50 dark:bg-red-900/30 p-2 rounded border border-red-100 dark:border-red-800/50 space-y-2">
                                                    <AutoExpandTextarea expand={expandCells} className="bg-white dark:bg-gray-700 text-gray-800 dark:text-white border-gray-200 dark:border-gray-600 focus:ring-red-500"
                                                        placeholder="4a. Critical Evidence (Source that contradicts)..." value={c.critique || ''} onChange={e => updateBrainstormField('cons', c.id, 'critique', e)} />
                                                    <AutoExpandTextarea expand={expandCells} className="bg-white dark:bg-gray-700 text-gray-800 dark:text-white border-gray-200 dark:border-gray-600 focus:ring-red-500"
                                                        placeholder="4b. Explain Gap (Evaluate limitations)..." value={c.explainCritique || ''} onChange={e => updateBrainstormField('cons', c.id, 'explainCritique', e)} />
                                                </div>

                                                <AutoExpandTextarea expand={expandCells} className="bg-gray-50 dark:bg-gray-700 text-gray-800 dark:text-white border-gray-200 dark:border-gray-600 focus:ring-red-400"
                                                    placeholder="5. Link (~50w: Summarise -> Link thesis -> Hint next)..." value={c.link || ''} onChange={e => updateBrainstormField('cons', c.id, 'link', e)} />
                                                <AutoExpandTextarea expand={expandCells} className="bg-indigo-50 dark:bg-indigo-900/30 text-gray-800 dark:text-white border-indigo-100 dark:border-indigo-800/50 focus:ring-indigo-500"
                                                    placeholder="6. Mini Conclusion (~50w: Which side is better?)..." value={c.miniConclusion || ''} onChange={e => updateBrainstormField('cons', c.id, 'miniConclusion', e)} />
                                            </div>
                                        </div>
                                    ))}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            );

            const renderSources = () => (
                <div className="space-y-6">
                    <div className="bg-indigo-50 dark:bg-indigo-900/20 p-6 rounded-xl shadow-sm border border-indigo-100 dark:border-indigo-800/50">
                        <h2 className="text-xl font-bold text-indigo-900 dark:text-indigo-300 mb-2 flex items-center gap-2">🔍 Research Toolkit</h2>
                        <div className="grid grid-cols-2 md:grid-cols-3 gap-3">
                            <a href="https://notebooklm.google.com" target="_blank" className="bg-white dark:bg-gray-800 p-3 rounded-lg border border-indigo-200 dark:border-gray-700 hover:shadow-md hover:border-indigo-400 text-sm flex flex-col"><span className="font-bold text-gray-800 dark:text-gray-200">NotebookLM</span><span className="text-xs text-gray-500">Summaries & Podcasts</span></a>
                            <a href="https://consensus.app" target="_blank" className="bg-white dark:bg-gray-800 p-3 rounded-lg border border-indigo-200 dark:border-gray-700 hover:shadow-md hover:border-indigo-400 text-sm flex flex-col"><span className="font-bold text-gray-800 dark:text-gray-200">Consensus</span><span className="text-xs text-gray-500">AI Academic Search</span></a>
                            <a href="https://scholar.google.com" target="_blank" className="bg-white dark:bg-gray-800 p-3 rounded-lg border border-indigo-200 dark:border-gray-700 hover:shadow-md hover:border-indigo-400 text-sm flex flex-col"><span className="font-bold text-gray-800 dark:text-gray-200">Google Scholar</span><span className="text-xs text-gray-500">Broad Literature Search</span></a>
                        </div>
                    </div>

                    <div className="bg-white dark:bg-gray-800 p-6 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700">
                        <div className="flex justify-between items-center mb-6">
                            <div>
                                <h2 className="text-2xl font-bold text-gray-800 dark:text-white mb-2">2. Sources (Sheet 2)</h2>
                                <p className="text-gray-500 dark:text-gray-400 text-sm">Prioritize "Peer Reviewed" and "Textbook" sources for higher marks.</p>
                            </div>
                        </div>
                        
                        <h3 className="font-bold text-lg text-gray-700 dark:text-gray-300 mb-3 border-b border-gray-200 dark:border-gray-700 pb-2">Introduction Needs</h3>
                        <div className="space-y-4 mb-8">
                            <input type="text" placeholder="Opening Stat / Quote" className="w-full p-2 bg-white dark:bg-gray-700 text-gray-800 dark:text-white border border-gray-300 dark:border-gray-600 rounded" value={currentSources.introStat} onChange={e => updateSources("introStat", e.target.value)} />
                            <div className="grid grid-cols-2 gap-4">
                                <input type="text" placeholder="Define Word 1 & Source" className="w-full p-2 bg-white dark:bg-gray-700 text-gray-800 dark:text-white border border-gray-300 dark:border-gray-600 rounded" value={currentSources.introDef1} onChange={e => updateSources("introDef1", e.target.value)} />
                                <input type="text" placeholder="Define Word 2 & Source" className="w-full p-2 bg-white dark:bg-gray-700 text-gray-800 dark:text-white border border-gray-300 dark:border-gray-600 rounded" value={currentSources.introDef2} onChange={e => updateSources("introDef2", e.target.value)} />
                            </div>
                        </div>

                        <div className="flex justify-between items-center mb-3 border-b border-gray-200 dark:border-gray-700 pb-2">
                            <h3 className="font-bold text-lg text-gray-700 dark:text-gray-300">Body Paragraph Sources</h3>
                            <button onClick={addBodySource} className="text-sm bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 px-3 py-1 rounded font-bold hover:bg-gray-200 dark:hover:bg-gray-600">+ Add Source Tracker</button>
                        </div>
                        <div className="space-y-4 mb-8">
                            {currentSources.bodySources.map((src, idx) => {
                                const isHighQuality = src.type === "Peer-Reviewed Journal" || src.type === "Academic Textbook";
                                return (
                                <div key={src.id} className={`flex gap-3 items-start bg-gray-50 dark:bg-gray-900/50 p-4 rounded-lg border ${isHighQuality ? 'border-green-200 dark:border-green-800/50' : 'border-gray-200 dark:border-gray-700'}`}>
                                    <div className="font-bold text-gray-400 dark:text-gray-500 mt-2">{idx + 1}.</div>
                                    <div className="flex-1 space-y-3">
                                        <div className="flex justify-between items-center">
                                            <label className="text-xs font-bold text-gray-500 dark:text-gray-400 uppercase tracking-wide">Validity / Type</label>
                                            <select className={`text-xs font-bold p-1 rounded border outline-none ${isHighQuality ? 'bg-green-100 text-green-800 border-green-200' : 'bg-white text-gray-600 border-gray-300'}`} value={src.type || "Other/Unverified"} onChange={e => updateBodySource(src.id, "type", e.target.value)}>
                                                {SOURCE_TYPES.map(t => <option key={t} value={t}>{t}</option>)}
                                            </select>
                                        </div>
                                        <input type="text" placeholder="Argument to prove..." className="w-full p-2 text-sm bg-white dark:bg-gray-700 text-gray-800 dark:text-white border border-gray-300 dark:border-gray-600 rounded" value={src.point} onChange={e => updateBodySource(src.id, "point", e.target.value)} />
                                        <textarea placeholder="Notes (Zubi, 2022 - discovered that...)" className="w-full p-2 text-sm bg-white dark:bg-gray-700 text-gray-800 dark:text-white border border-gray-300 dark:border-gray-600 rounded resize-y" rows="2" value={src.source} onChange={e => updateBodySource(src.id, "source", e.target.value)}></textarea>
                                        <input type="text" placeholder="Full Citation (from MyBib)..." className="w-full p-2 text-sm bg-white dark:bg-gray-700 text-gray-800 dark:text-white border border-gray-300 dark:border-gray-600 rounded" value={src.fullRef || ""} onChange={e => updateBodySource(src.id, "fullRef", e.target.value)} />
                                    </div>
                                    <button onClick={() => removeBodySource(src.id)} className="text-red-400 font-bold p-2 bg-white dark:bg-gray-800 rounded border border-red-100 dark:border-red-900">✕</button>
                                </div>
                            )})}
                        </div>

                        <div className="mt-8 pt-6 border-t-2 border-gray-200 dark:border-gray-700">
                            <h3 className="font-bold text-xl text-gray-800 dark:text-white mb-2">📚 Master Reference List</h3>
                            <textarea className="w-full p-4 bg-white dark:bg-gray-700 text-gray-800 dark:text-gray-100 border border-gray-300 dark:border-gray-600 rounded-lg outline-none min-h-[150px] text-sm font-serif" value={currentSources.bibliography || ""} onChange={e => updateSources("bibliography", e.target.value)} placeholder="Zubi, A. (2022)..." />
                        </div>
                    </div>
                </div>
            );

            const renderIntro = () => (
                <div className="space-y-6 bg-white dark:bg-gray-800 p-6 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700">
                    <h2 className="text-2xl font-bold text-gray-800 dark:text-white">3. Introduction (Sheet 3)</h2>
                    <p className="text-gray-500 dark:text-gray-400 text-sm mb-6">Target: ~250 words total. (Syncs with Setup tab).</p>

                    <WordCountTextarea label="Stat/Opening (50 words)" target={50} value={essay.intro.statOpening} onChange={v => updateIntro("statOpening", v)} helpText="Shocking fact or quote." />
                    <WordCountTextarea label="Background/Value (50 words)" target={50} value={essay.intro.background} onChange={v => updateIntro("background", v)} helpText="What is debated? Since when?" />
                    <WordCountTextarea label="Define Words (50 words)" target={50} value={essay.intro.defineWords} onChange={v => updateIntro("defineWords", v)} helpText="Define process words/measures." />
                    <WordCountTextarea label="Thesis Statement (50 words)" target={50} value={essay.intro.thesis} onChange={v => { updateIntro("thesis", v); updateSetup("thesis", v); }} helpText="One clear line. Simple enough for a child. No Evidence here!" />
                    <WordCountTextarea label="Structure (50 words)" target={50} value={essay.intro.structure} onChange={v => updateIntro("structure", v)} helpText="Signposts for each body paragraph." />
                </div>
            );

            const renderBody = () => (
                <div className="space-y-6">
                    <div className="flex justify-between items-center bg-white dark:bg-gray-800 p-6 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 mb-4">
                        <div>
                            <h2 className="text-2xl font-bold text-gray-800 dark:text-white">4. Body Paragraphs (Sheet 1 & 3)</h2>
                            <p className="text-indigo-700 dark:text-indigo-300 text-sm font-semibold mt-2 bg-indigo-50 dark:bg-indigo-900/30 inline-block p-1.5 px-3 rounded-md">
                                💡 Tip: 1500w = 3 Pros & 3 Cons. Ensure equal representation!
                            </p>
                        </div>
                        <div className="flex gap-2">
                            <button onClick={() => addParagraph("PRO")} className="bg-green-600 text-white px-4 py-2 rounded-lg text-sm font-bold hover:bg-green-700">+ Add PRO Point</button>
                            <button onClick={() => addParagraph("COUNTER")} className="bg-red-600 text-white px-4 py-2 rounded-lg text-sm font-bold hover:bg-red-700">+ Add COUNTER Point</button>
                        </div>
                    </div>

                    {essay.bodyParas.map((para, index) => (
                        <div key={para.id} className={`bg-white dark:bg-gray-800 p-6 rounded-xl shadow-sm border-t-8 ${para.type === 'PRO' ? 'border-green-500' : 'border-red-500'}`}>
                            <div className="flex justify-between items-center mb-6">
                                <h3 className={`text-xl font-bold ${para.type === 'PRO' ? 'text-green-800 dark:text-green-400' : 'text-red-800 dark:text-red-400'}`}>
                                    Paragraph {index + 1}: {para.type} Argument
                                </h3>
                                <button onClick={() => removeParagraph(para.id)} className="text-red-400 dark:text-red-500 text-sm font-bold hover:underline">Remove Paragraph</button>
                            </div>

                            <WordCountTextarea label="Signpost & Point (50 words)" target={50} value={para.signpost} onChange={v => updateBodyPara(para.id, "signpost", v)} helpText={para.type === 'PRO' ? "Link from above. Key claim." : "Start with a 'However' alternative (e.g. Conversely, Nevertheless). Then state Counter claim."} />
                            
                            <div className="bg-gray-50 dark:bg-gray-900/50 p-4 rounded-lg border border-gray-200 dark:border-gray-700 mb-5">
                                <h4 className="font-bold text-gray-700 dark:text-gray-300 mb-2 text-sm">Synthesize Evidence (Top Grades)</h4>
                                <WordCountTextarea label="Source 1 (e.g. Jon, 2023)" target={50} value={para.source} onChange={v => updateBodyPara(para.id, "source", v)} />
                                <WordCountTextarea label="Source 2 (e.g. Zubi, 2022)" target={50} value={para.source2 || ""} onChange={v => updateBodyPara(para.id, "source2", v)} helpText="Merge a second paper to strengthen the point." />
                            </div>

                            <WordCountTextarea label="Explain - Relevance (75+ words)" target={75} value={para.explain} onChange={v => updateBodyPara(para.id, "explain", v)} helpText="Don't rephrase! Link to theory. (Use phrasebank: 'This demonstrates...')" />
                            
                            <div className="bg-orange-50 dark:bg-orange-900/20 p-4 rounded-lg border border-orange-200 dark:border-orange-800/50 mb-5">
                                <h4 className="font-bold text-orange-800 dark:text-orange-400 mb-2 text-sm">Critical Analysis</h4>
                                <WordCountTextarea label="Critical Evidence (50 words)" target={50} value={para.critical} onChange={v => updateBodyPara(para.id, "critical", v)} helpText="Contradict the evidence you supplied above." />
                                <WordCountTextarea label="Explain Limitation/Gap (75 words)" target={75} value={para.explainCritique || ""} onChange={v => updateBodyPara(para.id, "explainCritique", v)} helpText="Where do they contradict? Why is it relevant? Evaluate limitations." />
                            </div>

                            <WordCountTextarea label="(Optional) Add Case Study (50 words)" target={50} value={para.caseStudy} onChange={v => updateBodyPara(para.id, "caseStudy", v)} />
                            <WordCountTextarea label="Summary & Link (50 words)" target={50} value={para.link} onChange={v => updateBodyPara(para.id, "link", v)} helpText="'That argument...' -> 'Main argument...' -> 'Next argument...'" />
                            
                            {para.type === "COUNTER" && (
                                <div className="mt-6 pt-6 border-t-2 border-dashed border-gray-200 dark:border-gray-700 bg-red-50 dark:bg-red-900/20 p-4 rounded">
                                    <WordCountTextarea label="Mini Conclusion: Evaluation (50 words)" target={50} value={para.evaluation} onChange={v => updateBodyPara(para.id, "evaluation", v)} helpText="Weigh Pro vs Counter. Which is stronger?" />
                                </div>
                            )}
                        </div>
                    ))}
                </div>
            );

            const renderConclusion = () => (
                <div className="space-y-6 bg-white dark:bg-gray-800 p-6 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700">
                    <h2 className="text-2xl font-bold text-gray-800 dark:text-white">5. Conclusion (Sheet 3)</h2>
                    <WordCountTextarea label="Summarise points (50 words)" target={50} value={essay.conclusion.summarise} onChange={v => updateConclusion("summarise", v)} />
                    <WordCountTextarea label="Evaluate & Answer Thesis (50 words)" target={50} value={essay.conclusion.evaluate} onChange={v => updateConclusion("evaluate", v)} />
                    <WordCountTextarea label="Limitations of Essay (50 words)" target={50} value={essay.conclusion.limitations} onChange={v => updateConclusion("limitations", v)} />
                    <WordCountTextarea label="Future Thoughts & Clincher (25 words)" target={25} value={essay.conclusion.future} onChange={v => updateConclusion("future", v)} />
                </div>
            );

            const renderCompile = () => {
                const text = compileFullEssay();
                
                const proWords = essay.bodyParas.filter(p => p.type === 'PRO').reduce((acc, p) => acc + countWords(`${p.signpost} ${p.source} ${p.source2 || ''} ${p.explain} ${p.critical} ${p.explainCritique || ''} ${p.caseStudy} ${p.link}`), 0);
                const conWords = essay.bodyParas.filter(p => p.type === 'COUNTER').reduce((acc, p) => acc + countWords(`${p.signpost} ${p.source} ${p.source2 || ''} ${p.explain} ${p.critical} ${p.explainCritique || ''} ${p.caseStudy} ${p.link} ${p.evaluation || ''}`), 0);
                const totalDebate = proWords + conWords || 1;
                const proPercent = Math.round((proWords / totalDebate) * 100);
                const conPercent = 100 - proPercent;
                
                const targetCount = parseInt(currentSetup.targetWordCount) || 1500;
                const actualWords = countWords(text);
                const inRange = actualWords >= Math.floor(targetCount * 0.9) && actualWords <= Math.ceil(targetCount * 1.1);

                return (
                    <div className="space-y-6 bg-white dark:bg-gray-800 p-6 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 h-full flex flex-col">
                        <div className="flex justify-between items-center">
                            <h2 className="text-2xl font-bold text-gray-800 dark:text-white">Review & Export</h2>
                        </div>
                        
                        <div className="bg-gray-50 dark:bg-gray-900/50 p-4 rounded-lg border border-gray-200 dark:border-gray-700">
                            <h4 className="font-bold text-gray-800 dark:text-gray-200 mb-2 text-sm flex justify-between">
                                <span>⚖️ Debate Balance (Target ~50/50)</span>
                                <span>Total Body Words: {proWords + conWords}</span>
                            </h4>
                            <div className="w-full h-4 bg-gray-200 dark:bg-gray-700 rounded-full flex overflow-hidden">
                                <div className="bg-green-500 h-full flex items-center justify-center text-[10px] text-white font-bold" style={{ width: `${proPercent}%` }}>{proPercent}% PRO</div>
                                <div className="bg-red-500 h-full flex items-center justify-center text-[10px] text-white font-bold" style={{ width: `${conPercent}%` }}>{conPercent}% CON</div>
                            </div>
                        </div>

                        <div className="bg-indigo-50 dark:bg-indigo-900/20 p-4 rounded-lg border border-indigo-200 dark:border-indigo-800/50">
                            <h4 className="font-bold text-indigo-900 dark:text-indigo-300 mb-2">✅ Pre-Submission Checklist</h4>
                            <ul className="text-sm text-indigo-800 dark:text-indigo-400 space-y-1 ml-4 list-disc marker:text-indigo-400">
                                <li>Remove subheadings and ensure formal language.</li>
                                <li>Check font size, page count, and marking sheet headers.</li>
                                <li>Run through Grammarly or "Read Aloud" in Word.</li>
                                <li>Ask AI (Gemini) to critique the final draft.</li>
                            </ul>
                        </div>

                        <div className="flex-1 bg-gray-50 dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-lg p-6 font-serif text-gray-800 dark:text-gray-100 whitespace-pre-wrap overflow-y-auto leading-loose text-lg">
                            {text || "Start writing in the tabs to see your compiled essay here."}
                        </div>

                        <button onClick={() => copyToClipboard(text)} className="w-full bg-indigo-600 dark:bg-indigo-500 text-white font-bold text-lg py-4 rounded-lg shadow-lg hover:bg-indigo-700 dark:hover:bg-indigo-600 transition mt-4">
                            Copy Essay & References (Interleaved)
                        </button>
                    </div>
                );
            };

            const tabs = [
                { id: "setup", icon: "📝", label: "Setup & Brainstorm" },
                { id: "sources", icon: "📚", label: "Sheet 2: Sources" },
                { id: "intro", icon: "🚀", label: "Sheet 3: Intro" },
                { id: "body", icon: "⚖️", label: `Body Paras (${essay.bodyParas.length})` },
                { id: "conc", icon: "🏁", label: "Conclusion" },
                { id: "compile", icon: "📄", label: "Compile" }
            ];

            return (
                <div className="flex w-full h-full overflow-hidden">
                    <div className="w-64 bg-white dark:bg-gray-800 border-r border-gray-200 dark:border-gray-700 flex flex-col shadow-sm shrink-0">
                        <div className="p-4 border-b border-gray-200 dark:border-gray-700">
                            <h3 className="font-bold text-gray-800 dark:text-white truncate" title={essay.title}>{essay.title}</h3>
                            <div className="text-xs text-gray-500 dark:text-gray-400 font-medium mt-1">Due: {essay.dueDate || "Not set"}</div>
                        </div>
                        <nav className="flex-1 p-3 space-y-1 overflow-y-auto">
                            {tabs.map(t => (
                                <button key={t.id} onClick={() => setActiveTab(t.id)} 
                                    className={`w-full text-left px-4 py-3 rounded-lg text-sm font-bold transition flex items-center gap-3 ${activeTab === t.id ? 'bg-indigo-50 dark:bg-indigo-900/30 text-indigo-700 dark:text-indigo-300' : 'text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700'}`}>
                                    <span>{t.icon}</span> {t.label}
                                </button>
                            ))}
                        </nav>
                        
                        <div className="p-4 border-t border-gray-200 dark:border-gray-700 mt-auto bg-gray-50 dark:bg-gray-800/50">
                            <button onClick={() => setIsRefViewerOpen(!isRefViewerOpen)}
                                className={`w-full flex items-center justify-center gap-2 px-4 py-3 rounded-lg text-sm font-bold transition shadow-sm ${isRefViewerOpen ? 'bg-indigo-700 text-white hover:bg-indigo-800' : 'bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-600'}`}>
                                📎 {isRefViewerOpen ? 'Close Split-Screen' : 'Open Reference Viewer'}
                            </button>
                        </div>
                    </div>

                    <div className="flex-1 flex overflow-hidden">
                        <div className={`overflow-y-auto p-6 relative transition-all duration-300 ${isRefViewerOpen ? 'w-1/2 border-r border-gray-300 dark:border-gray-700' : 'flex-1'}`}>
                            <div className={`${isRefViewerOpen ? 'w-full' : 'max-w-4xl mx-auto'} h-full transition-all`}>
                                {activeTab === 'setup' && renderSetup()}
                                {activeTab === 'sources' && renderSources()}
                                {activeTab === 'intro' && renderIntro()}
                                {activeTab === 'body' && renderBody()}
                                {activeTab === 'conc' && renderConclusion()}
                                {activeTab === 'compile' && renderCompile()}
                            </div>
                        </div>

                        {isRefViewerOpen && (
                            <div className="w-1/2 flex flex-col bg-gray-50 dark:bg-gray-900 h-full z-10 relative">
                                <div className="p-3 border-b border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 flex justify-between items-center shadow-sm shrink-0">
                                    <div>
                                        <h3 className="font-bold text-gray-800 dark:text-white flex items-center gap-2">📎 Reference Viewer</h3>
                                        <p className="text-xs text-gray-400 dark:text-gray-500">Loads temporarily to save browser memory.</p>
                                    </div>
                                    <button onClick={() => setIsRefViewerOpen(false)} className="text-gray-500 dark:text-gray-400 hover:text-red-500 dark:hover:text-red-400 font-bold px-3 py-1 bg-gray-100 dark:bg-gray-700 rounded-md transition text-sm">✕ Close</button>
                                </div>
                                
                                <div className="p-3 border-b border-gray-200 dark:border-gray-700 bg-gray-100 dark:bg-gray-800/80 flex flex-col gap-3 shrink-0">
                                    <div className="flex gap-2">
                                        <input type="file" multiple accept="image/*,application/pdf,.txt" onChange={handleFileUpload}
                                            className="block w-full text-sm text-gray-500 dark:text-gray-400 file:mr-2 file:py-1.5 file:px-3 file:rounded-md file:border-0 file:text-sm file:font-bold file:bg-indigo-600 file:text-white hover:file:bg-indigo-700 cursor-pointer shadow-sm flex-1" />
                                    </div>
                                    
                                    {referenceFiles.length > 0 && (
                                        <div className="flex gap-2 items-center justify-between">
                                            <select className="flex-1 p-1.5 text-sm bg-white dark:bg-gray-700 text-gray-800 dark:text-white border border-gray-300 dark:border-gray-600 rounded focus:ring-2 focus:ring-indigo-500 outline-none font-medium truncate"
                                                value={activeRefId || ""} onChange={e => setActiveRefId(e.target.value)}>
                                                {referenceFiles.map(f => <option key={f.id} value={f.id}>{f.name}</option>)}
                                            </select>
                                            
                                            <div className="flex items-center bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm overflow-hidden shrink-0">
                                                <button onClick={() => setDocZoom(z => Math.max(0.5, z - 0.25))} className="px-3 py-1 hover:bg-gray-100 dark:hover:bg-gray-600 text-gray-600 dark:text-gray-300 font-bold text-lg leading-none border-r border-gray-200 dark:border-gray-600">−</button>
                                                <span className="px-3 py-1 text-xs font-bold text-gray-600 dark:text-gray-300 min-w-[3.5rem] text-center">{Math.round(docZoom * 100)}%</span>
                                                <button onClick={() => setDocZoom(z => Math.min(3, z + 0.25))} className="px-3 py-1 hover:bg-gray-100 dark:hover:bg-gray-600 text-gray-600 dark:text-gray-300 font-bold text-lg leading-none border-l border-gray-200 dark:border-gray-600">+</button>
                                                <button onClick={() => setDocZoom(1)} className="px-3 py-1.5 bg-gray-50 dark:bg-gray-600 hover:bg-gray-200 dark:hover:bg-gray-500 text-xs font-bold text-gray-500 dark:text-gray-300 border-l border-gray-200 dark:border-gray-600">Reset</button>
                                            </div>

                                            <button onClick={() => removeReferenceFile(activeRefId)} className="bg-red-50 dark:bg-red-900/30 text-red-600 dark:text-red-400 px-3 py-1.5 rounded-md text-sm font-bold hover:bg-red-100 dark:hover:bg-red-900/50 transition border border-red-200 dark:border-red-800/50 shrink-0">
                                                Trash File
                                            </button>
                                        </div>
                                    )}
                                </div>

                                <div className="flex-1 bg-gray-300 dark:bg-gray-950 overflow-auto relative">
                                    {activeRefFile ? (
                                        <div className="w-full h-full p-4 flex items-start justify-center">
                                            <div className="zoom-container inline-block shadow-lg bg-white dark:bg-gray-800" style={{ transform: `scale(${docZoom})` }}>
                                                {activeRefFile.type.startsWith('image/') ? (
                                                    <img src={activeRefFile.url} alt="Reference" className="block max-w-none" />
                                                ) : (
                                                    <iframe src={activeRefFile.url} className="w-[800px] h-[1100px] border-0" title="Reference Document"></iframe>
                                                )}
                                            </div>
                                        </div>
                                    ) : (
                                        <div className="text-gray-500 dark:text-gray-600 text-sm flex flex-col items-center justify-center h-full p-8 text-center gap-2">
                                            <span className="text-4xl">📄</span>
                                            <p className="font-medium">No file selected.</p>
                                            <p className="text-xs">Upload a PDF, image, or text file above to view it side-by-side while you write.</p>
                                        </div>
                                    )}
                                </div>
                            </div>
                        )}
                    </div>

                    {showCheatSheet ? (
                        <div className="w-80 bg-white dark:bg-gray-800 border-l border-gray-200 dark:border-gray-700 flex flex-col shadow-lg z-20 text-sm shrink-0">
                            <div className="p-4 border-b border-gray-200 dark:border-gray-700 bg-indigo-50 dark:bg-indigo-900/30 flex justify-between items-center">
                                <h3 className="font-bold text-indigo-800 dark:text-indigo-300">Academic Phrasebank</h3>
                                <button onClick={() => setShowCheatSheet(false)} className="text-indigo-500 dark:text-indigo-400 hover:text-indigo-800 dark:hover:text-indigo-300 font-bold">Close</button>
                            </div>
                            <div className="flex-1 overflow-y-auto p-4 space-y-6">
                                <p className="text-xs text-gray-500 dark:text-gray-400 italic mb-2">Click any phrase to copy it.</p>
                                
                                {PHRASEBANK.map(group => (
                                    <div key={group.category}>
                                        <h4 className="font-bold text-gray-800 dark:text-gray-200 border-b border-gray-200 dark:border-gray-700 pb-1 mb-2">{group.category}</h4>
                                        <ul className="space-y-1">
                                            {group.phrases.map((phrase, i) => (
                                                <li key={i}>
                                                    <button onClick={() => copyToClipboard(phrase)} className="phrase-btn w-full text-left p-2 rounded bg-gray-50 dark:bg-gray-700/50 hover:bg-indigo-100 dark:hover:bg-indigo-900/50 text-gray-700 dark:text-gray-300 hover:text-indigo-800 dark:hover:text-indigo-300 transition border border-transparent hover:border-indigo-200 dark:hover:border-indigo-700 text-xs">
                                                        {phrase}
                                                    </button>
                                                </li>
                                            ))}
                                        </ul>
                                    </div>
                                ))}

                                <div>
                                    <h4 className="font-bold text-gray-800 dark:text-gray-200 border-b border-gray-200 dark:border-gray-700 pb-1 mb-2">Process Words</h4>
                                    <ul className="space-y-2 text-xs text-gray-600 dark:text-gray-400">
                                        {PROCESS_WORDS.map(pw => (
                                            <li key={pw.word}><strong className="text-gray-800 dark:text-gray-200">{pw.word}:</strong> {pw.def}</li>
                                        ))}
                                    </ul>
                                </div>
                            </div>
                        </div>
                    ) : (
                        <div className="bg-indigo-700 dark:bg-indigo-900 text-white flex items-center justify-center w-10 cursor-pointer hover:bg-indigo-600 dark:hover:bg-indigo-800 transition shrink-0" onClick={() => setShowCheatSheet(true)}>
                            <span className="transform -rotate-90 origin-center text-xs font-bold tracking-widest whitespace-nowrap block mt-10">
                                PHRASEBANK
                            </span>
                        </div>
                    )}
                </div>
            );
        }

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
</body>
</html>


